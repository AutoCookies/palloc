prefix=/usr/local
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libpalloc
Description: A compact general purpose allocator with excellent performance
Version: 2.2
URL: https://github.com/microsoft/palloc/
Libs: -L${libdir} -lpalloc
Libs.private:  -lpthread -lrt -latomic
Cflags: -I${includedir}
