prefix=@CMAKE_INSTALL_PREFIX@
libdir=@pa_pc_libdir@
includedir=@pa_pc_includedir@

Name: @PROJECT_NAME@
Description: A compact general purpose allocator with excellent performance
Version: @PACKAGE_VERSION@
URL: https://github.com/microsoft/palloc/
Libs: -L${libdir} -l@pa_libname@
Libs.private: @pa_pc_libraries@
Cflags: -I${includedir}
